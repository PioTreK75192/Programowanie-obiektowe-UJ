<!DOCTYPE html>
<html>
<head>
    <title>Lista Kategorii</title>
</head>
<body>
    <h1>Kategorie</h1>
    <table border="1">
        <tr>
            <th>ID</th>
            <th>Nazwa</th>
        </tr>
        {% for category in categories %}
            <tr>
                <td>{{ category.id }}</td>
                <td>{{ category.name }}</td>
            </tr>
        {% else %}
            <tr><td colspan="2">Brak kategorii.</td></tr>
        {% endfor %}
    </table>
</body>
</html>
