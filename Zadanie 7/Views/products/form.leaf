<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#(title)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Magazyn</a>
            <div class="navbar-nav">
                <a class="nav-link active" href="/products">Produkty</a>
                <a class="nav-link" href="/categories">Kategorie</a>
                <a class="nav-link" href="/suppliers">Dostawcy</a>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <section class="d-flex align-items-center justify-content-between gap-3 mb-4">
            <div>
                <p class="text-uppercase text-primary fw-semibold small mb-1">Formularz</p>
                <h1 class="h2 mb-0">#(title)</h1>
            </div>
            <a class="btn btn-outline-secondary" href="/products">Powrot</a>
        </section>

        <form class="bg-white border rounded p-4" method="post" action="#(action)">
            <div class="mb-3">
                <label class="form-label" for="name">Nazwa</label>
                <input class="form-control" id="name" type="text" name="name" value="#(product.name)" required>
            </div>

            <div class="mb-3">
                <label class="form-label" for="description">Opis</label>
                <textarea class="form-control" id="description" name="description" rows="4" required>#(product.description)</textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="price">Cena</label>
                    <input class="form-control" id="price" type="number" name="price" value="#(product.price)" step="0.01" min="0" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="stock">Stan</label>
                    <input class="form-control" id="stock" type="number" name="stock" value="#(product.stock)" min="0" required>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label" for="categoryID">Kategoria</label>
                    <select class="form-select" id="categoryID" name="categoryID" required>
                        #for(category in categories):
                        <option value="#(category.id)" #(category.selected)>#(category.name)</option>
                        #endfor
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label" for="supplierID">Dostawca</label>
                    <select class="form-select" id="supplierID" name="supplierID" required>
                        #for(supplier in suppliers):
                        <option value="#(supplier.id)" #(supplier.selected)>#(supplier.name)</option>
                        #endfor
                    </select>
                </div>
            </div>

            <button class="btn btn-primary" type="submit">#(submitLabel)</button>
        </form>
    </main>
</body>
</html>
