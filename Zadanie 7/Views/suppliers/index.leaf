<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dostawcy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Magazyn</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/products">Produkty</a>
                <a class="nav-link" href="/categories">Kategorie</a>
                <a class="nav-link active" href="/suppliers">Dostawcy</a>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <section class="d-flex align-items-center justify-content-between gap-3 mb-4">
            <div>
                <p class="text-uppercase text-primary fw-semibold small mb-1">CRUD</p>
                <h1 class="h2 mb-0">Dostawcy</h1>
            </div>
            <a class="btn btn-primary" href="/suppliers/new">Nowy dostawca</a>
        </section>

        <section class="table-responsive bg-white border rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th>Produkty</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    #for(supplier in suppliers):
                    <tr>
                        <td><strong>#(supplier.name)</strong></td>
                        <td>#(supplier.email)</td>
                        <td>#(supplier.phone)</td>
                        <td>#(supplier.productsCount)</td>
                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="/suppliers/#(supplier.id)/edit">Edytuj</a>
                                <form method="post" action="/suppliers/#(supplier.id)/delete">
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Usun</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    #endfor
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>
