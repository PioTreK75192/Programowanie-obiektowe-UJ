<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#(title)</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Magazyn</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/products">Produkty</a>
                <a class="nav-link" href="/categories">Kategorie</a>
                <a class="nav-link active" href="/suppliers">Dostawcy</a>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <section class="d-flex align-items-center justify-content-between gap-3 mb-4">
            <div>
                <p class="text-uppercase text-primary fw-semibold small mb-1">Formularz</p>
                <h1 class="h2 mb-0">#(title)</h1>
            </div>
            <a class="btn btn-outline-secondary" href="/suppliers">Powrot</a>
        </section>

        <form class="bg-white border rounded p-4 col-lg-8" method="post" action="#(action)">
            <div class="mb-3">
                <label class="form-label" for="name">Nazwa</label>
                <input class="form-control" id="name" type="text" name="name" value="#(supplier.name)" required>
            </div>

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" type="email" name="email" value="#(supplier.email)" required>
            </div>

            <div class="mb-3">
                <label class="form-label" for="phone">Telefon</label>
                <input class="form-control" id="phone" type="text" name="phone" value="#(supplier.phone)" required>
            </div>

            <button class="btn btn-primary" type="submit">#(submitLabel)</button>
        </form>
    </main>
</body>
</html>
