<!doctype html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Magazyn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Magazyn</a>
            <div class="navbar-nav">
                <a class="nav-link" href="/products">Produkty</a>
                <a class="nav-link" href="/categories">Kategorie</a>
                <a class="nav-link" href="/suppliers">Dostawcy</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        <section class="p-5 bg-white border rounded-3">
            <p class="text-uppercase text-primary fw-semibold small mb-2">Vapor + Leaf + Fluent + Redis</p>
            <h1 class="display-5 fw-bold">Panel zarzadzania produktami</h1>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a class="btn btn-primary" href="/products">Produkty</a>
                <a class="btn btn-outline-primary" href="/categories">Kategorie</a>
                <a class="btn btn-outline-primary" href="/suppliers">Dostawcy</a>
            </div>
        </section>
    </main>
</body>
</html>
